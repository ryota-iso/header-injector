{
  "name": "@header-injector/extension",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "node scripts/build-extension.mjs all",
    "build:chrome": "node scripts/build-extension.mjs chrome",
    "build:safari": "node scripts/build-extension.mjs safari",
    "build:safari:ios": "node scripts/safari-shell.mjs prepare",
    "build:safari:ios:rebuild": "node scripts/safari-shell.mjs rebuild",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test run --passWithNoTests --environment node"
  },
  "dependencies": {
    "@header-injector/core": "workspace:*",
    "@header-injector/ui-options": "workspace:*",
    "solid-js": "catalog:runtime"
  },
  "devDependencies": {
    "typescript": "catalog:build",
    "vite": "catalog:build",
    "vite-plugin-solid": "catalog:build",
    "vitest": "catalog:test"
  }
}
